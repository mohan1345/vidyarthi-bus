<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.VidyarthiBus" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bus_blue_light</item>
        <item name="colorPrimaryVariant">@color/bus_blue_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/route_green_light</item>
        <item name="colorSecondaryVariant">@color/route_green</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:navigationBarColor">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
